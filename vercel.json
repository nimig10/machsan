{
  "rewrites": [
    { "source": "/((?!api/|@vite|@react-refresh|@fs|node_modules/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/calendar-sync.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/notify-course-end-7days",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/production-deadline-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/productions-archive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/calendar-sync?reconcile=all&dryrun=1",
      "schedule": "0 4 * * *"
    }
  ]
}
