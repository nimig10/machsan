                    </div>
                  ))}
                </div>
              </>
            )}

            <div style={{display:"flex",gap:6,marginTop:8}}>
              <button className="btn btn-secondary btn-sm" onClick={appendLessonFromExisting}>➕ שיעור נוסף</button>
