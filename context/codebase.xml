          </div>
          <div style={{ fontSize:14, fontWeight:700, color:"var(--text)" }}>{getBookingTitle(booking)}</div>
          {subtitle && <div style={{ fontSize:12, color:"var(--text2)", marginTop:2 }}>{subtitle}</div>}
