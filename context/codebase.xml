                const matchesSearch = (eq) => !eqSearch || String(eq.name||"").toLowerCase().includes(eqSearch.toLowerCase());
                const visibleCats = (eqCatF.length>0 ? eqCatF : equipmentCategories).filter(cat =>
                  (equipment || []).some(eq =>
