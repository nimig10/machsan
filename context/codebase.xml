  }, []);

  const getBookingColor = useCallback((booking) => {
    const kind = getBookingKind(booking);
    if (kind === "lesson") return LESSON_COLOR;
    if (kind === "team") return TEAM_COLOR;
    if (booking?.isNight) return NIGHT_COLOR;
    return STUDENT_COLOR;
