                    {active ? "✅ " : ""}{loanType === "סאונד" ? "השאלת סאונד" : loanType === "הפקה" ? "השאלת הפקה" : loanType === "קולנוע יומית" ? "השאלת קולנוע יומית" : "השאלה פרטית"}
                  </button>
                );
              })}
            </div>
          </div>
        </Modal>
      )}
    </div>
  );
}
