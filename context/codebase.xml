            </div>
            <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
              {/* פילטר זמן — השבוע / החודש */}
              {[
                { val: "all",   label: "הכל" },
                { val: "week",  label: "📅 השבוע" },
                { val: "month", label: "🗓️ החודש" },
