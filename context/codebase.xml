                ✕ בטל שיוך
              </button>
              <button className="btn btn-danger" disabled={conflictSending} onClick={confirmConflictAndSend}>
                {conflictSending ? "⏳ שולח..." : "✅ אשר ושלח מייל"}
              </button>
            </div>
          </div>
        </div>
      )}
      {mode ? (
        <LessonForm
          initial={editTarget}
          onSave={save}
          onCancel={()=>{setMode(null);setEditTarget(null);}}
