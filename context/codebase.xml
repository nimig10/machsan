    { key: "administration",  icon: "📋", title: "אדמיניסטרציה",   desc: "ניהול סטודנטים, אולפנים, שיעורים ודוחות",        color: "#8b5cf6" },
    { key: "staff-schedule",  icon: "📅", title: 'לו"ז עובדים',   desc: "הגשת העדפות, צפייה בשיבוצים ומשמרות",            color: "#0ea5e9" },
