      ) : (
        <>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:8,marginBottom:12,flexWrap:"wrap"}}>
            <div className="search-bar" style={{flex:1,minWidth:180}}><span>🔍</span>
