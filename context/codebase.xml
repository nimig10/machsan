                { key: "system-settings",  icon: "⚙️", label: "הגדרות מערכת",  color: "#f5a623" },
                { key: "activity-logs",    icon: "📊", label: "יומן פעילות",    color: "#3b82f6" },
              ].map(btn => (
                <button
                  key={btn.key}
                  onClick={() => onNavigate(btn.key)}
                  onMouseEnter={() => setHovered(btn.key)}
