{
  "output": {
    "filePath": "context/codebase.xml",
    "style": "xml",
    "compress": false
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".claude/**",
      "context/**",
      "repomix-output.xml",
      "*.lock",
      "*.log",
      "public/**",
      "*.png",
      "*.jpg",
      "*.svg",
      "*.ico",
      "*.woff",
      "*.woff2",
      "*.ttf",
      "database.types1.ts"
    ]
  },
  "security": {
    "enableSecurityCheck": false
  }
}
